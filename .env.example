# Скопируйте этот файл в .env и подставьте свои значения.
# Если ни одна переменная POSTGRES_* не задана — будет использоваться SQLite (db.sqlite3).

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=

# PostgreSQL (раскомментируйте, если хотите использовать PostgreSQL вместо SQLite).
# POSTGRES_DB=kindergarten
# POSTGRES_USER=kg_user
# POSTGRES_PASSWORD=kg_pass
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# Включается на managed-PostgreSQL (Render, Railway и т.п.) — требует SSL.
# POSTGRES_REQUIRE_SSL=True
